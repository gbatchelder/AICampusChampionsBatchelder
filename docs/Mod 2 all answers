def descriptive_stats(numbers):
    """
    Compute mean, median, and standard deviation for a list of numbers.

    Parameters
    ----------
    numbers : list of int or float
        A non-empty list of numeric values.

    Returns
    -------
    dict
        Keys: 'mean', 'median', 'standard_deviation'

    Example
    -------
    >>> descriptive_stats([2, 4, 4, 4, 5, 5, 7, 9])
    {'mean': 5.0, 'median': 4.5, 'standard_deviation': 2.0}
    """
    if not numbers:
        raise ValueError("Input list must not be empty.")

    n = len(numbers)

    # Mean
    mean = sum(numbers) / n

    # Median
    sorted_nums = sorted(numbers)
    mid = n // 2
    if n % 2 == 0:
        median = (sorted_nums[mid - 1] + sorted_nums[mid]) / 2
    else:
        median = sorted_nums[mid]

    # Population standard deviation
    variance = sum((x - mean) ** 2 for x in numbers) / n
    standard_deviation = variance ** 0.5

    return {
        "mean": mean,
        "median": median,
        "standard_deviation": standard_deviation,
    }
```

